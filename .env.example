# JobGraph Configuration - NEVER COMMIT .env.local
# This is a template. Copy to .env.local and fill with your actual values.
# WARNING: .env.local contains secrets and must NEVER be committed to Git!

# ============================================================================
# DATABASE - PostgreSQL Connection
# ============================================================================
DB_HOST=postgres
DB_PORT=5432
DB_NAME=jobgraph
# Generate strong password: openssl rand -hex 16
DB_PASSWORD=CHANGE_THIS_TO_STRONG_PASSWORD_32_CHARS_MIN

# ============================================================================
# ENCRYPTION - Master Key for Credential Encryption
# ============================================================================
# Generate with: openssl rand -hex 32
# NEVER hardcode, NEVER commit, NEVER share
MASTER_ENCRYPTION_KEY=CHANGE_THIS_TO_RANDOM_HEX_32_BYTES

# ============================================================================
# LLM PROVIDER - Google Gemini (Required for v0.1)
# ============================================================================
# Get from: https://cloud.google.com/console
# 1. Create Google Cloud Project
# 2. Enable Generative Language API
# 3. Create API key
GEMINI_API_KEY=AIza_CHANGE_THIS_TO_YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-1.5-pro

# Optional: Alternative LLM providers (v0.2+)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ============================================================================
# STORAGE - MinIO S3-Compatible Object Storage
# ============================================================================
MINIO_USER=minioadmin
# Generate strong password: openssl rand -hex 16
MINIO_PASSWORD=CHANGE_THIS_TO_STRONG_PASSWORD
MINIO_BUCKET=jobgraph

# ============================================================================
# CACHE & QUEUE - Valkey (Redis Successor)
# ============================================================================
VALKEY_HOST=valkey
VALKEY_PORT=6379
# Generate strong password: openssl rand -hex 16
VALKEY_PASSWORD=CHANGE_THIS_TO_STRONG_PASSWORD

# ============================================================================
# API CONFIGURATION
# ============================================================================
API_BASE_URL=http://localhost:8000
API_KEY=CHANGE_THIS_TO_RANDOM_32_CHAR_STRING
# Generate with: openssl rand -hex 16 | head -c 32

# ============================================================================
# FRONTEND - Next.js Configuration
# ============================================================================
NEXT_PUBLIC_API_URL=http://localhost:8000

# ============================================================================
# LOGGING & DEBUGGING
# ============================================================================
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
STRUCTURED_LOGGING=true
ENVIRONMENT=development  # development, staging, production

# ============================================================================
# SECURITY - SSL/TLS (Optional, for production)
# ============================================================================
# If deploying with HTTPS:
# SSL_CERT_PATH=/path/to/cert.pem
# SSL_KEY_PATH=/path/to/key.pem

# ============================================================================
# TELEMETRY (Optional, disabled by default)
# ============================================================================
# TELEMETRY_ENABLED=false  # Default: false (privacy-first)
# If enabled, JobGraph sends anonymous usage statistics only
# No personal data, credentials, or job details are sent

# ============================================================================
# JOB DISCOVERY - ATS Connector Refresh Intervals
# ============================================================================
# How often to refresh job postings from each ATS (seconds)
GREENHOUSE_SYNC_INTERVAL=3600    # 1 hour
LEVER_SYNC_INTERVAL=3600         # 1 hour
# WORKABLE_SYNC_INTERVAL=3600    # (v0.2+)

# ============================================================================
# BROWSER AUTOMATION - Playwright Configuration
# ============================================================================
PLAYWRIGHT_HEADLESS=true         # true for production, false for debugging
PLAYWRIGHT_TIMEOUT_MS=30000      # 30 seconds per operation
PLAYWRIGHT_RETRY_COUNT=3         # Retry failed form submissions 3x
PLAYWRIGHT_VIEWPORT_WIDTH=1280
PLAYWRIGHT_VIEWPORT_HEIGHT=720

# ============================================================================
# FEATURE FLAGS (Optional, for testing experimental features)
# ============================================================================
# FEATURE_BETA_MATCHING=false
# FEATURE_ADVANCED_TAILORING=false
# FEATURE_MULTI_LLM=false

# ============================================================================
# RATE LIMITING (Optional)
# ============================================================================
# RATE_LIMIT_PER_HOUR=100
# RATE_LIMIT_PER_DAY=500

# ============================================================================
# PORTAL CREDENTIALS (Optional, user-provided for each ATS)
# ============================================================================
# These are stored encrypted in the database via the API.
# DO NOT put credentials here; use the web dashboard to add them securely.
# Example format (stored encrypted after submission):
# LINKEDIN_COOKIES=b'session_id=...'  # (Added via dashboard, not here)
# GREENHOUSE_API_KEY=...               # (Added via dashboard, not here)

# ============================================================================
# NOTES FOR DEPLOYMENT
# ============================================================================
# 1. NEVER commit .env.local to version control
# 2. Use strong, randomly generated passwords (≥32 characters)
# 3. Rotate API keys monthly
# 4. Store .env.local securely (restricted file permissions: 600)
# 5. Backup .env.local securely (encrypted backup preferred)
# 6. Use different passwords for dev vs. production
# 7. Monitor logs for unauthorized access attempts
# 8. Enable only required features (minimize attack surface)
# 9. Keep Docker images updated (docker compose pull && docker compose up -d)
# 10. Review structured JSON logs regularly for anomalies

# ============================================================================
# QUICK START
# ============================================================================
# 1. Copy this file: cp .env.example .env.local
# 2. Edit .env.local with your actual values
# 3. Keep .env.local out of version control: git update-index --assume-unchanged .env.local
# 4. Start: docker compose up -d
# 5. Verify: docker compose ps
# 6. Check logs: docker compose logs -f backend
