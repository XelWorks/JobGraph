# Provenance: List of requirements files to watch for drift detection
requirements-sources:
  - docs/requirements.md

# Provenance: Active build cycle (CYCLE-N) or N/A if cycle-less project
active-cycle: N/A

# Provenance: Git branch base to diff changes against
active-base: main

# Provenance: Document frontmatter parser syntax format (yaml or html-comment)
frontmatter-format: yaml
